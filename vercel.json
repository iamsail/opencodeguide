{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/zh/opencode-install",
      "destination": "/zh/install",
      "permanent": true
    },
    {
      "source": "/en/mcp-explained",
      "destination": "/en/mcp",
      "permanent": true
    },
    {
      "source": "/zh/windows-wsl",
      "destination": "/zh/docs/windows-wsl/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/_next/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|gif|png|svg|ico|json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    }
  ]
}
